<Window x:Class="GameTranslator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Translator v3.0"
        Width="520" Height="460"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">

    <DockPanel>
        <Button x:Name="BtnToggle" DockPanel.Dock="Bottom" Width="120" Height="30" Margin="10"
                HorizontalAlignment="Right" Click="BtnToggle_Click" Content="开始"
                Foreground="White" BorderThickness="0">
            <Button.Resources>
                <Style TargetType="Border"><Setter Property="CornerRadius" Value="4" /></Style>
            </Button.Resources>
        </Button>

        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <StatusBarItem>
                <TextBlock x:Name="TxtStatus" Text="就绪" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="TxtVersion" Text="v2.0" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" FontSize="11" />
            </StatusBarItem>
        </StatusBar>

        <TabControl Margin="10" Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
            <TabItem Header="引擎配置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="15">
                        <Label Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}">捕获模式</Label>
                        <ComboBox x:Name="CmbCaptureMode" Margin="0,0,0,10">
                            <ComboBoxItem Content="全屏翻译" Tag="FullScreen" />
                            <ComboBoxItem Content="框选翻译" Tag="Region" />
                        </ComboBox>
                        <Label Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}">OCR 识别引擎</Label>
                        <ComboBox x:Name="CmbOcrEngine" Margin="0,0,0,10" SelectionChanged="CmbOcrEngine_SelectionChanged">
                            <ComboBoxItem Content="Windows OCR" Tag="Windows" />
                            <ComboBoxItem Content="腾讯云 OCR" Tag="Tencent" />
                        </ComboBox>
                        <Label x:Name="LblTencentId" Visibility="Collapsed" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}">腾讯云 SecretId</Label>
                        <TextBox x:Name="TxtTencentId" Visibility="Collapsed" Margin="0,0,0,10" />
                        <Label x:Name="LblTencentKey" Visibility="Collapsed" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}">腾讯云 SecretKey</Label>
                        <TextBox x:Name="TxtTencentKey" Visibility="Collapsed" Margin="0,0,0,10" />
                        <Separator Margin="0,5" />
                        <Label>翻译引擎</Label>
                        <ComboBox x:Name="CmbApiType" Margin="0,0,0,10" SelectionChanged="CmbApiType_SelectionChanged">
                            <ComboBoxItem Content="OpenAI 兼容" Tag="OpenAI" />
                            <ComboBoxItem Content="DeepL" Tag="DeepL" />
                            <ComboBoxItem Content="Google 翻译" Tag="Google" />
                        </ComboBox>
                        <Label x:Name="LblApiKey">API Key</Label>
                        <TextBox x:Name="TxtApiKey" Margin="0,0,0,10" />
                        <Label x:Name="LblEndpoint">API Endpoint</Label>
                        <TextBox x:Name="TxtApiEndpoint" Margin="0,0,0,10" />
                        <Label x:Name="LblModel">模型名称</Label>
                        <TextBox x:Name="TxtModelName" Margin="0,0,0,10" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="设置">
                <StackPanel Margin="15">
                    <Label>目标语言</Label>
                    <ComboBox x:Name="CmbTargetLang" Margin="0,0,0,10">
                        <ComboBoxItem Content="中文" Tag="Chinese" />
                        <ComboBoxItem Content="English" Tag="English" />
                        <ComboBoxItem Content="日本語" Tag="Japanese" />
                        <ComboBoxItem Content="한국어" Tag="Korean" />
                    </ComboBox>
                    <Label>快捷键</Label>
                    <Button x:Name="BtnHotkey" Click="BtnHotkey_Click" Content="Ctrl+Shift+T"
                            HorizontalAlignment="Left" Padding="10,4" Margin="0,0,0,10" MinWidth="140"
                            Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                            Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="3" /></Style>
                        </Button.Resources>
                    </Button>
                    <Label>目标显示器</Label>
                    <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                            BorderThickness="1" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" Padding="10" CornerRadius="4">
                        <ItemsControl x:Name="MonitorList">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
